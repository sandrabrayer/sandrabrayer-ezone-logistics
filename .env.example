# Copy to .env and fill with real values. .env is gitignored — never commit it.

# The Apps Script web app /exec URL for THIS app's deployment (not Dashboard/Managers).
APPS_SCRIPT_EXEC_URL=https://script.google.com/macros/s/REPLACE_WITH_DEPLOYMENT_ID/exec

# This app's own Google Sheet ID (the spreadsheet setupSheet() provisions).
SHEET_ID=REPLACE_WITH_SHEET_ID

# Frontend server port for local dev / Railway.
PORT=3000
